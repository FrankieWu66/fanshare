# Helius RPC API key (optional but recommended for devnet/mainnet reliability)
# Sign up free at https://helius.dev — 100k requests/day on free tier
# Without this, the app falls back to the public Solana RPC endpoints (rate-limited)
NEXT_PUBLIC_HELIUS_API_KEY=

# Cluster selection (default: localnet for development)
# Options: localnet | devnet | testnet | mainnet
NEXT_PUBLIC_DEFAULT_CLUSTER=localnet

# Vercel KV (Upstash Redis) — price history persistence
# Provision in Vercel dashboard → Storage → Create KV database
# Then copy credentials from the "env variables" tab.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# PostHog — product analytics + session replay
# Project key from https://us.posthog.com (Project Settings → Project ID)
# Without this, PostHog silently no-ops (Vercel Analytics still fires).
NEXT_PUBLIC_POSTHOG_KEY=
# Optional — override PostHog host. Defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_HOST=

# Tally — floating feedback button
# Form ID from tally.so (the short slug after "tally.so/r/" in your form URL).
# When unset, the floating button is hidden.
NEXT_PUBLIC_TALLY_FORM_ID=

# balldontlie.io — required for advanced stats (GOAT tier $39.99/mo)
# Rotation: update here AND in ~/.zshrc AND revoke old key at balldontlie.io issuer.
# Without this, the oracle cron logs a warning and advanced stats fields are null.
BALLDONTLIE_API_KEY=

# Resend — transactional email (free tier: 3k emails/mo, no credit card)
# Sign up at resend.com → API Keys → Create key
# Set in Vercel env vars (Production + Preview + Development) AND .env.local
RESEND_API_KEY=

# Email dry-run guard (default: true — safe during setup)
# Set to "false" ONLY after reviewing templates in Resend's preview/dashboard.
# When true: logs "would send to X" without calling Resend.
EMAIL_DRY_RUN=true

# Optional: custom Tally webhook signing secret (from Tally → webhook settings)
# When set, /api/webhook/tally validates HMAC-SHA256 signature on every request.
TALLY_WEBHOOK_SECRET=

# Optional: sender address override for waitlist welcome emails
# Default: "FanShare <noreply@fanshares.xyz>"
EMAIL_FROM_WAITLIST=

# Demo 1 invite gate — shared code for all 15 Demo 1 invitees.
# Include in invite links: fanshares.xyz/invite?code=<VALUE>
# Gate fails closed: if unset OR empty, /invite is fully blocked for everyone.
# Set in Vercel dashboard → Project → Environment Variables before sending invites.
NEXT_PUBLIC_DEMO_INVITE_CODE=
