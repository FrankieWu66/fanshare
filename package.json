{
  "name": "fanshare",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-deploy": "cd anchor && anchor deploy",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "init-players": "tsx scripts/init-players.ts",
    "init-tokenomics": "tsx scripts/init-tokenomics.ts",
    "oracle": "tsx scripts/oracle.ts",
    "oracle:mock": "tsx scripts/oracle.ts --mock",
    "reclaim-demo": "tsx scripts/reclaim-demo-kv.ts",
    "reset-kv": "tsx scripts/reset-kv.ts",
    "freeze-market": "tsx scripts/freeze-market.ts",
    "setup-webhook": "tsx scripts/setup-helius-webhook.ts",
    "build": "next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run build && npm run lint && npm run format:check && npm run test",
    "codama:js": "codama run js",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "setup": "npm run anchor-build && npm run codama:js",
    "start": "next start"
  },
  "description": "FanShare — Stock Market for Human Performance. Solana DEX for NBA player tokens.",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@solana/kit": "^6.3.0",
    "@solana/kit-client-rpc": "^0.7.0",
    "@solana/kit-plugin-rpc": "^0.7.0",
    "@solana/wallet-standard-features": "^1.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "dotenv": "^17.4.1",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.369.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "swr": "^2.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "anchor-bankrun": "^0.5.0",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "solana-bankrun": "^0.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
